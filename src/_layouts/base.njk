{% set lang = lang or "de" %}
{% set t = i18n[lang] %}
{% set prefix = "" if lang == "de" else "/" + lang %}
<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  {% if description %}<meta name="description" content="{{ description }}">{% endif %}

  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" sizes="48x48">
  <link rel="icon" href="/images/favicon-32x32.png" type="image/png" sizes="32x32">
  <link rel="icon" href="/images/favicon-16x16.png" type="image/png" sizes="16x16">
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#0a1628">

  <!-- Open Graph / WhatsApp -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ description or 'Zoe Barossi – Triathletin aus Berlin. Way to Nizza 2026.' }}">
  <meta property="og:image" content="https://zoe-barossi.statichost.page/images/og-image.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:url" content="https://zoe-barossi.statichost.page{{ prefix }}/{{ slug or '' }}">

  <link rel="stylesheet" href="/css/style.css">
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %} data-cms-path="{{ page.inputPath | replace('./', '') }}">
  <header>
    <nav>
      <button class="burger" aria-label="Menü" onclick="document.body.classList.toggle('nav-open')">
        <span></span><span></span><span></span>
      </button>
      <div class="nav-links">
        <a href="{{ prefix }}/">{{ t.nav.start }}</a>
        <a href="{{ prefix }}/{% if lang == 'de' %}der-weg{% elif lang == 'en' %}the-way{% else %}o-caminho{% endif %}/">{{ t.nav.way }}</a>
        <a href="{{ prefix }}/{% if lang == 'de' %}unterstuetzen{% elif lang == 'en' %}support{% else %}apoiar{% endif %}/">{{ t.nav.support }}</a>
        <a href="{{ prefix }}/{% if lang == 'de' %}ausruestung{% elif lang == 'en' %}gear{% else %}equipamento{% endif %}/">{{ t.nav.gear }}</a>
        <a href="{{ prefix }}/{% if lang == 'de' %}ueber{% elif lang == 'en' %}about{% else %}sobre{% endif %}/">{{ t.nav.about }}</a>
        <a href="{{ prefix }}/live/">{{ t.nav.live }}</a>
        <a href="{{ prefix }}/{% if lang == 'de' %}kontakt{% elif lang == 'en' %}contact{% else %}contato{% endif %}/">{{ t.nav.contact }}</a>
      </div>
      <div class="nav-right">
        <a href="https://www.instagram.com/zoebarossi" target="_blank" rel="noopener" class="social-icon" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <a href="https://www.strava.com/athletes/35981492" target="_blank" rel="noopener" class="social-icon" aria-label="Strava">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.463 0l-7 13.828h4.169"/></svg>
        </a>
        <a href="https://linktr.ee/zoebarossi" target="_blank" rel="noopener" class="social-icon" aria-label="Linktree">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M7.953 15.066l-.038-4.2 4.183-.006v-1.86H7.916l4.23-4.165-1.327-1.28L7.9 6.636l.008-4.062H5.926l.003 4.065L2.97 3.545 1.642 4.835l4.239 4.163H1.77v1.862l4.192.006-.038 4.2h2.029zm8.144 3.504L12.2 14.809l-1.318 1.322 3.894 3.776v3.519h1.982v-3.505l3.908-3.79-1.318-1.322-3.25 3.761z"/></svg>
        </a>
        <a href="https://twitch.tv/zoebarossi" target="_blank" rel="noopener" class="social-icon" aria-label="Twitch">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"/></svg>
        </a>
        <div class="lang-switch">
          <button class="lang-btn" aria-label="Sprache wählen">{{ lang | upper }} ▾</button>
          <div class="lang-dropdown">
            <a href="/{{ slugDe or slug or '' }}" {% if lang == 'de' %}class="lang-active"{% endif %}>DE</a>
            <a href="/en/{{ slugEn or slug or '' }}" {% if lang == 'en' %}class="lang-active"{% endif %}>EN</a>
            <a href="/pt/{{ slugPt or slug or '' }}" {% if lang == 'pt' %}class="lang-active"{% endif %}>PT</a>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer>
    <p>&copy; 2026 Zoe Barossi</p>
    <nav>
      <a href="{{ prefix }}/{% if lang == 'de' %}impressum{% elif lang == 'en' %}imprint{% else %}impressum{% endif %}/">{{ t.footer.imprint }}</a>
      <a href="{{ prefix }}/{% if lang == 'de' %}datenschutz{% elif lang == 'en' %}privacy{% else %}privacidade{% endif %}/">{{ t.footer.privacy }}</a>
    </nav>
  </footer>

  <script>
  // Sichtschutz — clientseitiger Passwortschutz
  (function() {
    if (window.location.pathname.startsWith('/admin')) return;
    if (sessionStorage.getItem('zb_access') === '1') return;
    var overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;inset:0;z-index:99999;background:#0a1628;display:flex;align-items:center;justify-content:center;flex-direction:column;font-family:-apple-system,Helvetica Neue,sans-serif;';
    overlay.innerHTML = '<div style="text-align:center;color:#e0e0e0;max-width:320px;padding:2rem;">' +
      '<h2 style="font-size:1.4rem;margin-bottom:0.5rem;font-weight:600;">Zoe Barossi</h2>' +
      '<p style="font-size:0.85rem;opacity:0.6;margin-bottom:2rem;">Website in Entwicklung</p>' +
      '<input id="pw-input" type="password" placeholder="Passwort" style="width:100%;padding:0.75rem 1rem;border:1px solid rgba(255,255,255,0.15);border-radius:8px;background:rgba(255,255,255,0.08);color:#fff;font-size:1rem;outline:none;box-sizing:border-box;margin-bottom:0.5rem;" autocomplete="off">' +
      '<p id="pw-error" style="color:#ff6b6b;font-size:0.8rem;min-height:1.2em;margin:0;"></p>' +
      '</div>';
    document.body.appendChild(overlay);
    document.body.style.overflow = 'hidden';
    var input = document.getElementById('pw-input');
    var error = document.getElementById('pw-error');
    input.focus();
    function checkPw(pw) {
      return crypto.subtle.digest('SHA-256', new TextEncoder().encode(pw)).then(function(buf) {
        return Array.from(new Uint8Array(buf)).map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
      });
    }
    input.addEventListener('keydown', function(e) {
      if (e.key !== 'Enter') return;
      checkPw(input.value).then(function(hash) {
        if (hash === 'd435f7c4234fda5d95712680fdf7ed90fc8fe63a096c8607f6043d96b947194a') {
          sessionStorage.setItem('zb_access', '1');
          overlay.remove();
          document.body.style.overflow = '';
        } else {
          error.textContent = 'Falsches Passwort';
          input.value = '';
        }
      });
    });
  })();
  </script>
  <script>
  // perfectCMS — Magic Link Auto-Login
  (function() {
    var params = new URLSearchParams(window.location.search);
    var magic = params.get('magic');
    if (!magic) return;
    var API = localStorage.getItem('cms_api_url') || 'https://perfectcmstm6mdmqs-zoe-cms-api.functions.fnc.fr-par.scw.cloud';
    fetch(API + '/api/login/magic', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token: magic })
    }).then(function(r) { return r.json(); }).then(function(d) {
      if (d.token) {
        localStorage.setItem('cms_token', d.token);
        history.replaceState({}, '', window.location.pathname);
        location.reload();
      }
    }).catch(function() {});
  })();
  </script>
  <script>
  // perfectCMS — Inline-Edit
  (function() {
    var token = localStorage.getItem('cms_token');
    if (!token) return;
    var API = localStorage.getItem('cms_api_url') || 'https://perfectcmstm6mdmqs-zoe-cms-api.functions.fnc.fr-par.scw.cloud';
    var PAGE_PATH = document.body.getAttribute('data-cms-path');
    if (!PAGE_PATH) return;
    if (!document.querySelector('[data-cms-field]')) return;

    var btn = document.createElement('button');
    btn.textContent = '✏ Bearbeiten';
    btn.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;z-index:9000;background:#0a84ff;color:#fff;border:none;padding:0.6rem 1.2rem;border-radius:8px;font-size:0.9rem;cursor:pointer;box-shadow:0 4px 20px rgba(0,0,0,0.3);font-family:sans-serif;';
    document.body.appendChild(btn);

    var logoutBtn = document.createElement('button');
    logoutBtn.textContent = '× Bearbeitung beenden';
    logoutBtn.style.cssText = 'position:fixed;bottom:1.5rem;right:10.5rem;z-index:9000;background:transparent;color:#999;border:1px solid rgba(150,150,150,0.35);padding:0.6rem 1.2rem;border-radius:8px;font-size:0.9rem;cursor:pointer;font-family:sans-serif;';
    logoutBtn.addEventListener('click', function() {
      localStorage.removeItem('cms_token');
      location.reload();
    });
    document.body.appendChild(logoutBtn);

    var editing = false, saveBar = null;
    btn.addEventListener('click', function() { editing ? cancel() : start(); });

    function start() {
      editing = true;
      btn.textContent = '✕ Abbrechen';
      document.querySelectorAll('[data-cms-field]').forEach(function(el) {
        el.contentEditable = 'true';
        el.style.outline = '2px dashed rgba(10,132,255,0.6)';
        el.style.borderRadius = '4px';
        el.style.padding = '2px';
      });
      saveBar = document.createElement('div');
      saveBar.style.cssText = 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);z-index:9001;background:#1a1a2e;color:#e0e0e0;padding:0.75rem 1.5rem;border-radius:12px;display:flex;gap:1rem;align-items:center;box-shadow:0 8px 30px rgba(0,0,0,0.5);font-family:sans-serif;font-size:0.9rem;';
      saveBar.innerHTML = '<span style="opacity:0.7;">Klick auf Text zum Bearbeiten</span><button id="cms-save" style="background:#0a84ff;color:#fff;border:none;padding:0.5rem 1.2rem;border-radius:6px;cursor:pointer;font-size:0.9rem;">Speichern</button>';
      document.body.appendChild(saveBar);
      document.getElementById('cms-save').addEventListener('click', save);
    }

    function cancel() {
      editing = false;
      btn.textContent = '✏ Bearbeiten';
      document.querySelectorAll('[data-cms-field]').forEach(function(el) {
        el.contentEditable = 'false';
        el.style.outline = '';
        el.style.borderRadius = '';
        el.style.padding = '';
      });
      if (saveBar) { saveBar.remove(); saveBar = null; }
    }

    function save() {
      var fields = {};
      document.querySelectorAll('[data-cms-field]').forEach(function(el) {
        fields[el.getAttribute('data-cms-field')] = el.innerHTML;
      });
      var savebtn = document.getElementById('cms-save');
      savebtn.textContent = '…'; savebtn.disabled = true;
      fetch(API + '/api/inline', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ path: PAGE_PATH, fields: fields })
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.error) { alert('Fehler: ' + d.error); savebtn.textContent = 'Speichern'; savebtn.disabled = false; return; }
        cancel();
        var toast = document.createElement('div');
        toast.textContent = '✓ Gespeichert — Seite wird gleich aktualisiert';
        toast.style.cssText = 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:#4caf50;color:#fff;padding:0.6rem 1.5rem;border-radius:8px;z-index:9999;font-family:sans-serif;font-size:0.9rem;';
        document.body.appendChild(toast);
        setTimeout(function() { toast.remove(); }, 3000);
      })
      .catch(function() { savebtn.textContent = 'Speichern'; savebtn.disabled = false; alert('Netzwerkfehler'); });
    }
  })();
  </script>
</body>
</html>
